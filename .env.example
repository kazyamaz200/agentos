# LiteLLM configuration
LITELLM_API_KEY=sk-local
LITELLM_BASE_URL=http://localhost:4000

# Model selection
AGENTOS_MODEL_CODER=coder
AGENTOS_MODEL_EMBEDDING=text-embedding-ada-002

# GitHub token (fallback for issue/PR/checks commands)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# GitHub App installation auth (preferred for repository write operations)
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY_FILE=
GITHUB_APP_PRIVATE_KEY=

# Optional comma-separated GitHub logins allowed to run sensitive automation
AGENTOS_ADMIN_USERS=

# Qdrant vector store (optional, uses local JSON store by default)
QDRANT_URL=http://localhost:6333

# Provider API keys (passed through to LiteLLM)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
